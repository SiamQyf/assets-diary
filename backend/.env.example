# Assets Diary backend environment variables example
# Copy this file to `.env` and fill with real credentials.

# Server
PORT=3000
JWT_SECRET=change_this_to_a_secure_secret

# SMTP (for sending verification and reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false # true if using SSL (465)
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Assets Diary <no-reply@example.com>"

# Google Drive (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Public backend URL (optional, used in email links when set)
PUBLIC_BACKEND_URL=http://localhost:3000
